rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — authenticated users can read/write their own document
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      // Allow drivers to update rider ratings (ratingSum, ratingCount, totalRides)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['ratingSum', 'ratingCount', 'totalRides']);
    }

    // Drivers collection — all authenticated users can read (for rider map), drivers can only write their own
    match /drivers/{driverId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == driverId;
    }

    // Rides collection — riders can create, both can read their own, drivers can update status
    match /rides/{rideId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null
        && (resource.data.riderId == request.auth.uid
            || resource.data.driverId == request.auth.uid);
      allow update: if request.auth != null
        && (resource.data.riderId == request.auth.uid
            || resource.data.driverId == request.auth.uid);
      // Allow drivers to read pending rides for ride matching
      allow read: if request.auth != null && resource.data.status == 'pending';
    }
  }
}
